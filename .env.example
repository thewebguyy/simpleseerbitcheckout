# Application
APP_ENV=development
APP_NAME="SeerBit Checkout"
APP_URL=http://localhost

# SeerBit
SEERBIT_PUBLIC_KEY=
SEERBIT_SECRET_KEY=
SEERBIT_CALLBACK_URL=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=seerbit_checkout
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# Session
SESSION_NAME=seerbit_session
SESSION_LIFETIME=3600

# Mail
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME="SeerBit Checkout"

# Webhook
WEBHOOK_ROUTE_SECRET=
